stateDiagram-v2
    [*] --> MenuPrincipal

    MenuPrincipal --> Opciones
    MenuPrincipal --> SeleccionarNivel
    MenuPrincipal --> Salir
    Opciones --> MenuPrincipal

    SeleccionarNivel --> CargarNivel
    CargarNivel --> Gameplay

    state Gameplay {

        [*] --> Exploracion

        Exploracion --> Combate : Encuentro enemigo
        Combate --> Exploracion : Enemigo derrotado

        Combate --> MuerteJugador : HP = 0
        Exploracion --> MuerteJugador : Caida al vacio

        Exploracion --> JefeFinal : Area especial
        JefeFinal --> Victoria : Jefe derrotado

        MuerteJugador --> GameOverInterno : Sin continues
        GameOverInterno --> [*]

    }

    Gameplay --> Pausa : ESC
    Pausa --> Gameplay : Continuar
    Pausa --> MenuPrincipal : Salir

    Gameplay --> Victoria : Nivel completado

    Victoria --> SiguienteNivel
    SiguienteNivel --> CargarNivel

    Gameplay --> GameOver
    GameOver --> MenuPrincipal

    Salir --> [*]