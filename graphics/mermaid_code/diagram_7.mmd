graph TD
    subgraph Planificación
        A[Inicio Semana] --> B[Revisión de objetivos]
        B --> C[Definir tareas]
        C --> D[Estimación de tiempo]
    end

    subgraph Desarrollo
        D --> E[Programación]
        E --> F{¿Hay bloqueos?}
        F -->|Sí| G[Reunión rápida equipo]
        F -->|No| H[Pruebas unitarias]
        G --> E
        H --> I[Documentación]
    end

    subgraph Integración
        I --> J[Integración código]
        J --> K[Pruebas de integración]
        K --> L{¿Pruebas OK?}
        L -->|Sí| M[Build]
        L -->|No| N[Identificar error]
        N --> E
    end

    subgraph Retrospectiva
        M --> O[Revisión de logros]
        O --> P[Identificar mejoras]
        P --> Q[Actualizar backlog]
        Q --> R[Fin Semana]
    end